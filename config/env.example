# OpenClaw Docker Environment Variables
# Copy this to .env and fill in your values
# Usage: docker run --env-file config/.env ...

# ── Model Providers ──────────────────────────────────────
# Uncomment the provider(s) you use

# Mistral (recommended for tool calling)
# MISTRAL_API_KEY=your-mistral-api-key

# OpenAI
# OPENAI_API_KEY=sk-proj-your-openai-key

# Ollama — no key needed, uses baseUrl in openclaw.json

# ── Slack Owner ID ────────────────────────────────────────
# Your Slack user ID (find in Slack profile → ⋯ → Copy member ID)
# Required for owner-only tools (cron, gateway)
# Set in openclaw.json as: "ownerAllowFrom": ["slack:YOUR-ID"]
SLACK_USER_ID=YOUR-SLACK-USER-ID

# ── Gmail & Google Calendar (gog CLI) ────────────────────
GOG_ACCOUNT=you@gmail.com
GOG_KEYRING_PASSWORD=openclaw-local

# ── Fathom (Meeting Notes) ───────────────────────────────
# Get from: Fathom Settings → API → Generate key
FATHOM_API_KEY=your-fathom-api-key

# ── HubSpot CRM ──────────────────────────────────────────
# Get from: HubSpot Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na2-your-hubspot-token
